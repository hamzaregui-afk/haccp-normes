# ─── GLOBAL ───────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── POSTGRES ─────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_postgres_password

# ─── REDIS ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password

# ─── RABBITMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_USER=haccp
RABBITMQ_PASSWORD=change_me_rabbitmq_password

# ─── MINIO (S3-compatible object storage) ─────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_password

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_min_32_chars_long_secret_key_here
JWT_REFRESH_SECRET=change_me_refresh_min_32_chars_long_key

# ─── INTERNAL SERVICE SECURITY ────────────────────────────────────────────────
# Pre-shared secret for internal microservice-to-microservice calls (audit endpoint).
# Must be at least 32 chars in production. Never expose in client-side code.
INTERNAL_SERVICE_SECRET=change_me_min_32_chars_internal_secret_key

# ─── NOTIFICATIONS ────────────────────────────────────────────────────────────
FCM_SERVER_KEY=your_firebase_cloud_messaging_server_key
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your_smtp_password

# ─── MONITORING ───────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=change_me_grafana_password

# ─── WEB APP (Vite) ───────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:80
VITE_WS_URL=ws://localhost:80

# ─── SERVICE PORTS (for local dev without Docker) ─────────────────────────────
# auth-service:           3010
# user-service:           3011
# control-service:        3012
# nonconformity-service:  3013
# asset-service:          3014
# notification-service:   3015
# report-service:         3016
# dlc-service:            3017
# tenant-service:         3018
# audit-service:          3019
