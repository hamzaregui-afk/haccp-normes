# Auth Service environment variables
# Copy to .env and fill in real values before running

NODE_ENV=development

# Server
PORT=3010

# Database — each service owns its own DB
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/haccp_auth

# JWT — must be at least 32 characters
JWT_SECRET=change_me_min_32_chars_long_secret_key
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_me_refresh_min_32_chars_long
JWT_REFRESH_EXPIRES_IN=30d

# Audit service integration (internal Docker network)
AUDIT_SERVICE_URL=http://audit-service:3019
# Pre-shared secret for internal service-to-service calls — must match audit-service INTERNAL_SERVICE_SECRET
INTERNAL_SERVICE_SECRET=haccp-internal-dev-secret-change-in-prod
