// asset-service owns: Product, Equipment, Supplier

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String    @id @default(cuid())
  code        String
  name        String
  packaging   String?
  category    String
  dlcDays     Int?      @map("dlc_days")
  tempStorage Float?    @map("temp_storage")
  supplierId  String?   @map("supplier_id")
  tenantId    String    @map("tenant_id")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")

  supplier Supplier? @relation(fields: [supplierId], references: [id])

  @@unique([code, tenantId])
  @@index([tenantId])
  @@map("products")
}

model Equipment {
  id           String   @id @default(cuid())
  code         String
  name         String
  type         String?
  serialNumber String?  @map("serial_number")
  brand        String?
  siteId       String?  @map("site_id")  // FK to tenant-service (no join)
  tempMin      Float?   @map("temp_min")
  tempMax      Float?   @map("temp_max")
  tenantId     String   @map("tenant_id")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([code, tenantId])
  @@index([tenantId])
  @@map("equipments")
}

model Supplier {
  id        String    @id @default(cuid())
  code      String
  name      String
  vat       String?
  phone     String?
  email     String?
  address   String?
  tenantId  String    @map("tenant_id")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")

  products Product[]

  @@unique([code, tenantId])
  @@index([tenantId])
  @@map("suppliers")
}

enum DocumentCategory {
  PROCEDURE
  RECIPE
  OTHER
}

model Document {
  id         String           @id @default(cuid())
  tenantId   String           @map("tenant_id")
  name       String
  category   DocumentCategory
  mimeType   String           @map("mime_type")
  sizeBytes  Int              @map("size_bytes")
  objectKey  String           @map("object_key")
  url        String
  createdAt  DateTime         @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([category])
  @@map("documents")
}

enum DocRequestStatus {
  PENDING
  FULFILLED
  REJECTED
}

model DocumentRequest {
  id          String           @id @default(cuid())
  tenantId    String           @map("tenant_id")
  requesterId String           @map("requester_id")
  title       String
  description String?
  category    DocumentCategory?
  status      DocRequestStatus @default(PENDING)
  fulfillerId String?          @map("fulfiller_id")
  documentId  String?          @map("document_id")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([status])
  @@map("document_requests")
}
