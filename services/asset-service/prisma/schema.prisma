// asset-service owns: Product, Equipment, Supplier

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String    @id @default(cuid())
  code        String
  name        String
  packaging   String?
  category    String
  dlcDays     Int?      @map("dlc_days")
  tempStorage Float?    @map("temp_storage")
  supplierId  String?   @map("supplier_id")
  tenantId    String    @map("tenant_id")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")

  supplier Supplier? @relation(fields: [supplierId], references: [id])

  @@unique([code, tenantId])
  @@index([tenantId])
  @@map("products")
}

model Equipment {
  id           String   @id @default(cuid())
  code         String
  name         String
  type         String?
  serialNumber String?  @map("serial_number")
  brand        String?
  siteId       String?  @map("site_id")  // FK to tenant-service (no join)
  tempMin      Float?   @map("temp_min")
  tempMax      Float?   @map("temp_max")
  tenantId     String   @map("tenant_id")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([code, tenantId])
  @@index([tenantId])
  @@map("equipments")
}

model Supplier {
  id        String    @id @default(cuid())
  code      String
  name      String
  vat       String?
  phone     String?
  email     String?
  address   String?
  tenantId  String    @map("tenant_id")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")

  products Product[]

  @@unique([code, tenantId])
  @@index([tenantId])
  @@map("suppliers")
}
