// dlc-service owns: DlcLabel (printed labels log)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DlcLabel {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  productId   String   @map("product_id")   // FK to asset-service (no join)
  productName String   @map("product_name") // Denormalised for label printing speed
  producedAt  DateTime @map("produced_at")
  expiresAt   DateTime @map("expires_at")
  printedBy   String   @map("printed_by")   // userId
  printedAt   DateTime @default(now()) @map("printed_at")

  @@index([tenantId])
  @@index([expiresAt])
  @@map("dlc_labels")
}
