{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "paths": {
      "@haccp/shared-types": ["../../packages/shared-types/src/index.ts"],
      "@haccp/shared-utils": ["../../packages/shared-utils/src/index.ts"],
      "@haccp/shared-errors": ["../../packages/shared-errors/src/index.ts"],
      "@haccp/shared-validators": ["../../packages/shared-validators/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "coverage"]
}
