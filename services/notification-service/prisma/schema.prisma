generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Notification {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")        // target user
  type      String                          // NC_CREATED | TASK_OVERDUE | REPORT_VALIDATED | ...
  title     String
  body      String
  isRead    Boolean  @default(false) @map("is_read")
  link      String?                         // Deep link, e.g. /nonconformities/id
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}
