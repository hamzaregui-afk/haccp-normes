NODE_ENV=development
PORT=3015

# Database
DATABASE_URL=postgresql://haccp_user:password@localhost:5432/notification_db

# Auth
JWT_SECRET=change_me_min_32_chars_long_secret_key

# Redis (Socket.io adapter)
REDIS_URL=redis://localhost:6379

# RabbitMQ — consumes domain events from haccp_notification_queue
# Publishers: nonconformity-service, control-service, report-service
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# SMTP — omit in development to use Ethereal test account (preview URL logged to console)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=your_smtp_password
# SMTP_FROM=NORMES HACCP <noreply@example.com>

# App URL (used in email links)
APP_URL=http://localhost:5173

ALLOWED_ORIGINS=http://localhost:5173
