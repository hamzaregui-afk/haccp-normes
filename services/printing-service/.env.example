# ── Server ────────────────────────────────────────────────────────────────────
PORT=3021
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/haccp_printing

# ── Messaging ─────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters in production
JWT_SECRET=dev-jwt-secret-change-in-production-minimum-32-chars

# ── Internal service communication ────────────────────────────────────────────
INTERNAL_SERVICE_SECRET=dev-secret-change-in-production

# ── Audit service ─────────────────────────────────────────────────────────────
AUDIT_SERVICE_URL=http://localhost:3019/api/v1
