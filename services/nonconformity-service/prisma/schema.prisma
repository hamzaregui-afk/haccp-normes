// nonconformity-service owns: NonConformity, NCPhoto

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum NCStatus {
  OPEN
  IN_PROGRESS
  CLOSED
  REJECTED
}

enum NCSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NCCategory {
  TEMPERATURE
  HYGIENE
  LABELING
  TRACEABILITY
  EQUIPMENT
  SUPPLIER
  PROCESS
  OTHER
}

model NonConformity {
  id               String      @id @default(cuid())
  // ARCH-DECISION: reference is unique PER TENANT, not globally.
  // The original @unique global constraint caused P2002 failures when two
  // different tenants both tried to create their first NC of the year:
  // generateReference() counts per-tenant (→ both get NC-YYYY-0001) while the
  // DB enforced global uniqueness, making every second-tenant's first NC fail.
  // @@unique([reference, tenantId]) matches the per-tenant semantics exactly.
  reference        String                           // NC-YYYY-NNNN format, per-tenant
  tenantId         String      @map("tenant_id")
  siteId           String      @map("site_id")      // FK to tenant-service (no join)
  productId        String?     @map("product_id")   // FK to asset-service (no join)
  reporterId       String      @map("reporter_id")  // FK to user-service (no join)
  closedById       String?     @map("closed_by_id")
  status           NCStatus    @default(OPEN)
  severity         NCSeverity  @default(MEDIUM)
  category         NCCategory  @default(OTHER)
  description      String
  correctiveAction String?     @map("corrective_action")
  closedAt         DateTime?   @map("closed_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  photos NCPhoto[]

  @@unique([reference, tenantId])           // per-tenant reference uniqueness (see above)
  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@map("non_conformities")
}

model NCPhoto {
  id              String        @id @default(cuid())
  nonConformityId String        @map("non_conformity_id")
  url             String        // MinIO presigned URL
  uploadedAt      DateTime      @default(now()) @map("uploaded_at")

  nonConformity NonConformity @relation(fields: [nonConformityId], references: [id])

  @@map("nc_photos")
}
