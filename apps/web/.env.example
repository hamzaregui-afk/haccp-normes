# ─── NORMES HACCP — Web App Environment ───────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# Vite reads VITE_* variables at build time.

# API Gateway base URL — all REST and WebSocket traffic goes through here.
# Dev:  http://localhost:80   (nginx Docker gateway)
# Prod: https://api.normeshaccp.com
VITE_API_URL=http://localhost:80

# WebSocket base URL for Socket.io (notification-service).
# Leave empty to use the same origin as VITE_API_URL (default in nginx proxy setup).
# VITE_WS_URL=

# App version — injected at build time by CI (optional)
# VITE_APP_VERSION=1.0.0
