# NORMES HACCP — Local Print Agent configuration
# Copy this file to .env and fill in your values

# URL of your HACCP SaaS platform
HACCP_API_URL=https://178.105.126.165

# Credentials of a user with OPERATOR or ADMIN role
HACCP_EMAIL=operator@votreentreprise.com
HACCP_PASSWORD=MotDePasseSecurise

# Polling interval in milliseconds (default: 5000 = 5 seconds)
POLL_INTERVAL_MS=5000

# Log level: debug | info | warn | error
LOG_LEVEL=info
