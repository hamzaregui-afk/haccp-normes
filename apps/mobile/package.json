{
  "name": "@haccp/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "dev": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext ts,tsx",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@haccp/shared-types": "workspace:*",
    "@haccp/shared-utils": "workspace:*",
    "@haccp/shared-validators": "workspace:*",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.9.26",
    "@tanstack/react-query": "^5.28.0",
    "axios": "^1.6.8",
    "expo": "~50.0.0",
    "expo-build-properties": "~0.11.1",
    "expo-camera": "~14.0.0",
    "expo-print": "~12.6.0",
    "expo-secure-store": "~13.0.0",
    "expo-sharing": "~11.10.0",
    "react": "18.2.0",
    "react-native": "0.73.6",
    "react-native-safe-area-context": "4.8.2",
    "react-native-screens": "~3.29.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.3",
    "@types/jest": "^29.5.12",
    "@types/react": "~18.2.74",
    "@types/react-native": "^0.73.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "jest-expo": "~50.0.4",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterFramework": [],
    "setupFilesAfterEnv": [
      "<rootDir>/src/test-setup.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|@tanstack)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$":             "<rootDir>/src/$1",
      "^@haccp/shared-types$": "<rootDir>/../../packages/shared-types/src",
      "^@haccp/shared-utils$": "<rootDir>/../../packages/shared-utils/src",
      "^@haccp/shared-validators$": "<rootDir>/../../packages/shared-validators/src"
    }
  }
}
