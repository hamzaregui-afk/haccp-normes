{
  "rabbit_version": "3.12.0",
  "rabbitmq_version": "3.12.0",
  "users": [],
  "vhosts": [{ "name": "/" }],
  "permissions": [],
  "exchanges": [],
  "queues": [
    {
      "name": "haccp_notification_queue",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-dead-letter-exchange": "",
        "x-dead-letter-routing-key": "haccp_notification_dlq",
        "x-message-ttl": 60000
      }
    },
    {
      "name": "haccp_notification_dlq",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],
  "bindings": [],
  "policies": [
    {
      "vhost": "/",
      "name": "ha-all",
      "pattern": "haccp_.*",
      "apply-to": "queues",
      "definition": {
        "ha-mode": "all",
        "ha-sync-mode": "automatic"
      },
      "priority": 0
    }
  ]
}
