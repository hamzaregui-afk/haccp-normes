{
  "expo": {
    "name": "NORMES HACCP",
    "slug": "normes-haccp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A3D2B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.normeshaccp.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A3D2B"
      },
      "package": "com.normeshaccp.app"
    },
    "plugins": [
      "expo-camera",
      "expo-secure-store"
    ]
  }
}
