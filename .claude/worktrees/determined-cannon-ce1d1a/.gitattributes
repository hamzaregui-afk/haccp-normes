# Normalize line endings: LF in the repo, checkout per-platform
* text=auto eol=lf

# Force LF for shell scripts (CRLF breaks bash)
*.sh text eol=lf

# Force LF for JS/TS/JSON/YAML source
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.env* text eol=lf

# Binary files — no line-ending conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.pdf  binary
*.zip  binary
