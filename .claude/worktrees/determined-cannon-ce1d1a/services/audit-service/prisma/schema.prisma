// audit-service owns: AuditLog
// CRITICAL: This schema is APPEND-ONLY. No UPDATE or DELETE operations — ever.
// This is a legal/regulatory requirement for HACCP compliance.
// RLS policy on the DB also enforces insert-only at the Postgres level.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")      // FK to user-service (no join)
  tenantId   String   @map("tenant_id")
  action     String                        // CREATE | UPDATE | DELETE | LOGIN | LOGOUT
  resource   String                        // users | products | controls | …
  resourceId String?  @map("resource_id")
  payload    Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  // No updatedAt — append-only by design
  @@index([tenantId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
