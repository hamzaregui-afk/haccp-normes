NODE_ENV=development
PORT=3013
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/haccp_nonconformities
JWT_SECRET=change_me_min_32_chars_long_secret_key

# Audit service integration (internal Docker network)
AUDIT_SERVICE_URL=http://audit-service:3019
# Pre-shared secret for internal service-to-service calls — must match audit-service INTERNAL_SERVICE_SECRET
INTERNAL_SERVICE_SECRET=haccp-internal-dev-secret-change-in-prod

# RabbitMQ — publishes nonconformity.nc.created domain events
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# MinIO — S3-compatible object storage for NC photo uploads
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=haccp-nc-photos
MINIO_USE_SSL=false
